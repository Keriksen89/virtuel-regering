NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── Map / globe ──────────────────────────────────────────────────────────────
# Cesium ion token — free at https://ion.cesium.com (3D terrain + OSM buildings)
CESIUM_ION_TOKEN=

# Google Maps Platform — Photorealistic 3D Tiles (🌍 button)
# Requires the Map Tiles API enabled + billing on the GCP project.
GOOGLE_MAPS_KEY=

# ── Live traffic feeds ───────────────────────────────────────────────────────
# AIS live vessel feed — https://aisstream.io
AISSTREAM_API_KEY=

# OpenSky Network OAuth2 client — https://opensky-network.org (live aircraft)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Vejdirektoratet road/traffic events — https://data.vd.dk/user/register
VDAPI_KEY=

# ── Telecom / network layer (NETVÆRK view) ───────────────────────────────────
# OpenCelliD cell masts — https://opencellid.org
OPENCELLID_KEY=

# WiGLE WiFi hotspots — https://wigle.net/account
WIGLE_API_NAME=
WIGLE_API_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────────
# X / Twitter Bearer Token — feed falls back to RSS without it
X_BEARER_TOKEN=
