NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# AIS live vessel feed — get a key at https://aisstream.io
AISSTREAM_API_KEY=

# Cesium ion token — free at https://ion.cesium.com
CESIUM_ION_TOKEN=

# OpenSky Network OAuth2 client credentials — register at https://opensky-network.org
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Google Maps Platform (optional) — enables Photorealistic 3D Tiles
# GOOGLE_MAPS_KEY=
